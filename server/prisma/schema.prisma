generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Question {
  id        Int      @id
  question  String
  optionA   String
  optionB   String
  optionC   String
  optionD   String
  answer    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
