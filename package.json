{
  "name": "einbuergerungstest-trainer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"pnpm --filter ./server dev\"",
    "dev:fe": "vite",
    "dev:be": "pnpm --filter ./server dev",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:migrate": "pnpm --filter ./server exec prisma migrate dev",
    "db:seed": "pnpm --filter ./server exec prisma db seed"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.13.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "jsdom": "^24.1.3",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.0",
    "vite": "^6.1.0",
    "vitest": "^4.0.18"
  }
}
